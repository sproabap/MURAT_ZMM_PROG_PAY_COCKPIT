  @UI.lineItem: [ { position: 150 } ]
  VestingAmount;

  @UI.identification: [ { position: 152 } ]
  @UI.lineItem: [ { position: 152 } ]
  AdditionalTripBonusAmount;

  @UI.identification: [ { position: 154 } ]
  @UI.lineItem: [ { position: 154 } ]
  KMBonusAmount;

  @UI.identification: [ { position: 156 } ]
