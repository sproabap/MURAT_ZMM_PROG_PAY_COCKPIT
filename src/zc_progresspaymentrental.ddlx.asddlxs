@Metadata.layer: #CUSTOMER

//@UI.presentationVariant: [ { requestAtLeast: [ 'Currency' ] } ]

//@UI.headerInfo.typeNamePlural: '#( VestingModelDescription )'

@UI.presentationVariant: [ { requestAtLeast: [ 'CalendarYear',
                                               'CalendarMonth',
                                               'Supplier',
                                               'Product',
                                               'Customer',
                                               'ProductName',
                                               'VehicleCategory',
                                               'BonusAmount',
                                               'Currency',
                                               'BonusAmount',
                                               'ActualDays',
                                               'ActualTripCount',
                                               'ActualKM',
                                               'FuelVestingAmount',
                                               'TotalVestingAmount',
                                               'ScaleDetails',
                                               'PurchasingOrganization',
                                               'PurchasingOrganizationName',
                                               'PurchaseOrder',
                                               'POStatus',
                                               'POFilter' ] } ]

annotate entity ZC_ProgressPaymentRental with

{
  @Consumption.filter: { mandatory: true, selectionType: #SINGLE }
  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_CalendarYear', element: 'CalendarYear' } } ]
  @UI.facet: [ { label: 'General Information',
                 id: 'GeneralInfo',
                 purpose: #STANDARD,
                 position: 10,
                 type: #IDENTIFICATION_REFERENCE } ]
  @UI.identification: [ { position: 10 } ]
  @UI.lineItem: [ { position: 10 } ]
  @UI.selectionField: [ { position: 10 } ]
  CalendarYear;

  @Consumption.filter: { mandatory: true, selectionType: #SINGLE }
  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_CalendarMonth', element: 'CalendarMonth' } } ]
  @UI.identification: [ { position: 20 } ]
  @UI.lineItem: [ { position: 20 } ]
  @UI.selectionField: [ { position: 20 } ]
  CalendarMonth;

  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_Supplier_VH', element: 'Supplier' } } ]
  @UI.identification: [ { position: 30 } ]
  @UI.lineItem: [ { position: 30 } ]
  @UI.selectionField: [ { position: 30 } ]
  Supplier;

  @UI.hidden: true
  SupplierName;

  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_ProductStdVH', element: 'Product' } } ]
  @UI.identification: [ { position: 40 } ]
  @UI.lineItem: [ { position: 40 } ]
  @UI.selectionField: [ { position: 40 } ]
  Product;

  @UI.hidden: true
  ProductName;

  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_Customer_VH', element: 'Customer' } } ]
  @UI.identification: [ { position: 45 } ]
  @UI.lineItem: [ { position: 45 } ]
  @UI.selectionField: [ { position: 45 } ]
  Customer;

  @UI.hidden: true
  CustomerName;
 
//  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_DistributionChannel', element: 'DistributionChannel' } } ]
//  @UI.identification: [ { position: 47 } ]
