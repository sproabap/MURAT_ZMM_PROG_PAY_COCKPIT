  @Consumption.filter: { selectionType: #SINGLE, mandatory: true, defaultValue: '1010' }
  @Consumption.valueHelpDefinition: [ { entity: { name: 'I_PurchasingOrganization', element: 'PurchasingOrganization' } } ]
  @UI.identification: [ { position: 999 } ]
  @UI.lineItem: [ { position: 999 } ]
