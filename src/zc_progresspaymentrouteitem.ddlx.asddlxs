                                               'OriginDesc',
                                               'Arrivalprovincedesc',
                                               'Arrivaldistrictdesc',
                                               'DestDesc',
                                               'TemperatureRegimeDesc',
                                               'Currency',
                                               'PurchasingOrganization',
                                               'PurchasingOrganizationName' ] } ]

annotate entity ZC_ProgressPaymentRouteItem with
 
{
  @UI.facet: [ { label: 'Item',
                 id: 'item',
                 purpose: #STANDARD,
                 position: 10,
                 type: #IDENTIFICATION_REFERENCE } ]
  @UI.identification: [ { position: 10 } ]
  @UI.lineItem: [ { position: 10 } ]
  CalendarYear;

  @UI.identification: [ { position: 20 } ]
  @UI.lineItem: [ { position: 20 } ]
  CalendarMonth;

  @UI.identification: [ { position: 30 } ]
