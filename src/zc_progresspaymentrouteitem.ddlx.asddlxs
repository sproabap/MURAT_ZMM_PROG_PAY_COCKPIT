@Metadata.layer: #CUSTOMER

//@UI.headerInfo.typeNamePlural: '#(VestingModelDescription)'

@UI.presentationVariant: [ { requestAtLeast: [ 'SupplierName',
                                               'ProductName',
                                               'CustomerName',
                                               'Vehiclecategorydesc',
                                               'VehicleTypeDesc',
                                               'Vehiclebodydesc',
                                               'Vestingmodeldesc',
